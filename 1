<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">

    <title>Advanced DevOps Web Server</title>

    <style>

        *{
            margin:0;
            padding:0;
            box-sizing:border-box;
        }

        body{
            height:100vh;
            display:flex;
            justify-content:center;
            align-items:center;
            font-family:Arial, Helvetica, sans-serif;
            background: linear-gradient(135deg,#141e30,#243b55);
            overflow:hidden;
        }

        .container{
            width:700px;
            padding:40px;
            border-radius:20px;
            text-align:center;
            background:rgba(255,255,255,0.1);
            backdrop-filter:blur(10px);
            box-shadow:0 0 25px rgba(0,0,0,0.5);
            color:white;
            animation:fadeIn 2s ease;
        }

        h1{
            font-size:55px;
            color:#00ffd5;
            margin-bottom:20px;
            text-shadow:2px 2px 10px black;
        }

        h2{
            color:#ffd700;
            margin-bottom:20px;
        }

        p{
            font-size:20px;
            margin:10px 0;
            line-height:1.6;
        }

        .tech{
            margin-top:20px;
        }

        .tech span{
            display:inline-block;
            background:#ff6600;
            padding:10px 18px;
            margin:8px;
            border-radius:30px;
            font-size:18px;
            transition:0.4s;
        }

        .tech span:hover{
            background:#00ffd5;
            color:black;
            transform:scale(1.1);
        }

        .btn{
            display:inline-block;
            margin-top:30px;
            padding:15px 35px;
            font-size:20px;
            text-decoration:none;
            color:white;
            background:linear-gradient(45deg,#ff416c,#ff4b2b);
            border-radius:50px;
            transition:0.4s;
            box-shadow:0 0 15px rgba(255,75,43,0.5);
        }

        .btn:hover{
            transform:translateY(-5px);
            box-shadow:0 0 25px rgba(255,75,43,1);
        }

        .circle{
            position:absolute;
            border-radius:50%;
            background:rgba(255,255,255,0.1);
            animation:move 10s infinite alternate;
        }

        .circle1{
            width:200px;
            height:200px;
            top:-50px;
            left:-50px;
        }

        .circle2{
            width:300px;
            height:300px;
            bottom:-80px;
            right:-80px;
        }

        @keyframes fadeIn{
            from{
                opacity:0;
                transform:translateY(50px);
            }
            to{
                opacity:1;
                transform:translateY(0);
            }
        }

        @keyframes move{
            from{
                transform:translateY(0px);
            }
            to{
                transform:translateY(40px);
            }
        }

    </style>
</head>

<body>

    <div class="circle circle1"></div>
    <div class="circle circle2"></div>

    <div class="container">

        <h1>DevOps Deployment</h1>

        <h2>Web Server Running Successfully</h2>

        <p>
            Application deployed successfully using
            Jenkins CI/CD Pipeline.
        </p>

        <p>
            Hosted on AWS Cloud using Apache/Tomcat Server.
        </p>

        <div class="tech">
            <span>HTML</span>
            <span>CSS</span>
            <span>Jenkins</span>
            <span>Docker</span>
            <span>AWS</span>
            <span>Linux</span>
        </div>

        <a href="#" class="btn">
            Deployment Successful
        </a>

    </div>

</body>
</html>
