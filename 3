<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>DevOps Web Server</title>

    <style>
        body {
            margin: 0;
            padding: 0;
            font-family: Arial, sans-serif;
            background: linear-gradient(135deg, #1e3c72, #2a5298);
            color: white;
            text-align: center;
        }

        .container {
            margin-top: 120px;
        }

        h1 {
            font-size: 50px;
            color: #ffd700;
        }

        h2 {
            color: #00ffcc;
        }

        p {
            font-size: 20px;
        }

        .box {
            background-color: rgba(255, 255, 255, 0.1);
            width: 60%;
            margin: auto;
            padding: 30px;
            border-radius: 15px;
            box-shadow: 0px 0px 15px black;
        }

        .btn {
            display: inline-block;
            margin-top: 20px;
            padding: 12px 25px;
            background-color: #ff6600;
            color: white;
            text-decoration: none;
            border-radius: 8px;
            font-size: 18px;
        }

        .btn:hover {
            background-color: #ff3300;
        }
    </style>
</head>

<body>

    <div class="container">
        <div class="box">
            <h1>Welcome to DevOps World</h1>

            <h2>Web Server Successfully Running</h2>

            <p>
                This application is deployed using Jenkins CI/CD Pipeline.
            </p>

            <p>
                Technologies Used: HTML, CSS, Jenkins, Tomcat, AWS
            </p>

            <a href="#" class="btn">Deployment Successful</a>
        </div>
    </div>

</body>
</html>
